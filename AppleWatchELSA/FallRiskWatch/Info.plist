<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>ELSA Monitor</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>WKApplication</key>
	<true/>
	<key>WKWatchOnly</key>
	<true/>
	<key>WKBackgroundModes</key>
	<array>
		<string>workout-processing</string>
	</array>
	<key>NSHealthShareUsageDescription</key>
	<string>ELSA Monitor reads mobility, heart rate, activity, and walking steadiness data to estimate fall-risk signals.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>ELSA Monitor starts a walking workout session so the watch can collect heart-rate and motion context during monitoring.</string>
	<key>NSMotionUsageDescription</key>
	<string>ELSA Monitor uses watch motion to estimate gait regularity, sway, turns, and instability events.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ELSA Monitor uses live watch location during monitoring so alerts can be shown on the external dashboard map.</string>
</dict>
</plist>
